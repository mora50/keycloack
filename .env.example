# =============================================================================
# Auth Trust Gateway POC — example environment file
# Copy to .env and adjust as needed. .env is gitignored.
# Reference: specs/001-auth-trust-gateway/quickstart.md (Apêndice A)
# =============================================================================

# --- Keycloak admin bootstrap (DO NOT use these values outside the POC) -----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Base URL Keycloak emits inside the Compose network. Drives the `iss` claim.
KC_HOSTNAME_URL=http://keycloak:8080

# --- ms-auth -> Keycloak ----------------------------------------------------
MS_AUTH_KEYCLOAK_REALM=poc
MS_AUTH_KEYCLOAK_CLIENT_ID=poc-client

# --- Kong custom plugin -----------------------------------------------------
# Plugin source is mounted into /usr/local/share/lua/5.1/kong/plugins/<name>/
# so no LUA_PACKAGE_PATH override is needed.
KONG_PLUGINS=bundled,jwt-keycloak-validator
